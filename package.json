{
  "name": "find-changes-action",
  "version": "2.4.1",
  "private": true,
  "description": "Find which subdirectories have changes for input into a matrix build",
  "main": "lib/main.js",
  "scripts": {
    "build": "tsc",
    "format": "prettier --write **/*.ts",
    "format-check": "prettier --check **/*.ts",
    "lint": "eslint src/**/*.ts",
    "package": "ncc build --source-map --license licenses.txt",
    "test": "jest",
    "all": "npm run build && npm run format && npm run lint && npm run package && npm test",
    "version": "npm run build && npm run package && git add -- dist"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/smartlyio/find-changes-action.git"
  },
  "keywords": [
    "actions",
    "matrix"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "3.0.1",
    "@actions/exec": "3.0.0"
  },
  "devDependencies": {
    "@types/jest": "29.5.14",
    "@types/node": "24.12.4",
    "@typescript-eslint/parser": "5.6.0",
    "@vercel/ncc": "0.38.1",
    "eslint": "8.57.1",
    "eslint-plugin-github": "4.9.0",
    "eslint-plugin-jest": "27.9.0",
    "jest": "29.7.0",
    "jest-circus": "29.7.0",
    "js-yaml": "4.1.1",
    "prettier": "2.8.8",
    "ts-jest": "29.4.11",
    "typescript": "5.9.3"
  }
}
